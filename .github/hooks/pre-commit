#!/bin/sh
# Git pre-commit hook: Auto-update knowledge graph
# Calls PowerShell script to do the actual work

# Get the directory where this script lives
HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$HOOK_DIR/../.." && pwd)"

# Call PowerShell script
pwsh -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/.github/hooks/pre-commit.ps1"
exit $?
