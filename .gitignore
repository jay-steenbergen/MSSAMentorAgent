# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp

# .NET build artifacts (xUnit ProfileTests, any future .NET projects)
# These regenerate on every `dotnet test` run and pollute every commit.
**/bin/
**/obj/

# Build artifacts (knowledge graph)
.github/knowledge-graph/output/

# Knowledge graph runtime backups (auto-generated by mentor.ps1 writes)
*.bak

# IMPORTANT: DO NOT ignore .profiles/
# Learner profiles and progress tracking live here and MUST be committed to Git
# !.profiles/

# IMPORTANT: DO NOT ignore .github/
# Agent customizations live here
# !.github/
